    "def engineer_features(df):\n",
    "    df = df.copy()\n",
    "\n",
    "    # -----------------------------\n",
    "    # PassengerId features\n",
    "    # Format: gggg_pp\n",
    "    # -----------------------------\n",
    "    passenger_split = df[\"PassengerId\"].str.split(\"_\", expand=True).reindex(columns=[0, 1])\n",
    "    df[\"GroupId\"] = passenger_split[0]\n",
    "    df[\"PassengerNumber\"] = pd.to_numeric(passenger_split[1], errors=\"coerce\")\n",
    "    df[\"GroupSize\"] = df.groupby(\"GroupId\")[\"PassengerId\"].transform(\"count\")\n",
    "    df[\"IsAlone\"] = (df[\"GroupSize\"] == 1).astype(int)\n",
    "\n",
    "    # -----------------------------\n",
    "    # Cabin features\n",
    "    # Format: deck/num/side\n",
    "    # -----------------------------\n",
    "    cabin_split = df[\"Cabin\"].str.split(\"/\", expand=True).reindex(columns=[0, 1, 2])\n",
    "    df[\"Deck\"] = cabin_split[0]\n",
    "    df[\"CabinNum\"] = pd.to_numeric(cabin_split[1], errors=\"coerce\")\n",
    "    df[\"Side\"] = cabin_split[2]\n",
    "    df[\"CabinKnown\"] = df[\"Cabin\"].notna().astype(int)\n",
    "\n",
    "    # -----------------------------\n",
    "    # Spending features\n",
    "    # -----------------------------\n",
    "    spending_cols = [\"RoomService\", \"FoodCourt\", \"ShoppingMall\", \"Spa\", \"VRDeck\"]\n",
    "\n",
    "    df[\"TotalSpend\"] = df[spending_cols].sum(axis=1, min_count=1)\n",
    "    df[\"TotalSpend_filled0\"] = df[spending_cols].fillna(0).sum(axis=1)\n",
    "    df[\"NoSpend\"] = (df[\"TotalSpend_filled0\"] == 0).astype(int)\n",
    "    df[\"SpendCount\"] = (df[spending_cols].fillna(0) > 0).sum(axis=1)\n",
    "\n",
    "    df[\"LuxurySpend\"] = df[[\"RoomService\", \"Spa\", \"VRDeck\"]].fillna(0).sum(axis=1)\n",
    "    df[\"CommercialSpend\"] = df[[\"FoodCourt\", \"ShoppingMall\"]].fillna(0).sum(axis=1)\n",
    "    df[\"SpendPerUsedService\"] = df[\"TotalSpend_filled0\"] / df[\"SpendCount\"].replace(0, np.nan)\n",
    "\n",
    "    for col in spending_cols + [\"TotalSpend_filled0\", \"LuxurySpend\", \"CommercialSpend\"]:\n",
    "        df[f\"log_{col}\"] = np.log1p(df[col])\n",
    "\n",
    "    # -----------------------------\n",
    "    # Age features\n",
    "    # -----------------------------\n",
    "    df[\"AgeGroup\"] = pd.cut(\n",
    "        df[\"Age\"],\n",
    "        bins=[-1, 12, 18, 30, 45, 60, 100],\n",
    "        labels=[\"Child\", \"Teen\", \"YoungAdult\", \"Adult\", \"SeniorAdult\", \"Senior\"]\n",
    "    )\n",
    "\n",
    "    df[\"IsChild\"] = (df[\"Age\"] < 13).astype(float)\n",
    "    df.loc[df[\"Age\"].isna(), \"IsChild\"] = np.nan\n",
    "\n",
    "    # -----------------------------\n",
    "    # Interaction features\n",
    "    # -----------------------------\n",
    "    df[\"Route\"] = (\n",
    "        df[\"HomePlanet\"].astype(\"object\").fillna(\"Missing\").astype(str)\n",
    "        + \"_to_\"\n",
    "        + df[\"Destination\"].astype(\"object\").fillna(\"Missing\").astype(str)\n",
    "    )\n",
    "\n",
    "    df[\"DeckSide\"] = (\n",
    "        df[\"Deck\"].astype(\"object\").fillna(\"Missing\").astype(str)\n",
    "        + \"_\"\n",
    "        + df[\"Side\"].astype(\"object\").fillna(\"Missing\").astype(str)\n",
    "    )\n",
    "\n",
    "    # -----------------------------\n",
    "    # Name / surname features\n",
    "    # -----------------------------\n",
    "    df[\"Surname\"] = df[\"Name\"].str.split().str[-1]\n",
    "    df[\"FamilySize\"] = df.groupby(\"Surname\")[\"PassengerId\"].transform(\"count\")\n",
    "    df.loc[df[\"Surname\"].isna(), \"FamilySize\"] = np.nan\n",
    "\n",
    "    return df\n",
    "\n",
    "\n",
    "train_fe = train.copy()\n",
    "test_fe = test.copy()\n",
    "\n",
    "train_fe[\"dataset\"] = \"train\"\n",
    "test_fe[\"dataset\"] = \"test\"\n",
    "test_fe[TARGET] = np.nan\n",
    "\n",
    "full = pd.concat([train_fe, test_fe], axis=0, ignore_index=True)\n",
    "full_fe = engineer_features(full)\n",
    "\n",
    "train_eda = full_fe[full_fe[\"dataset\"] == \"train\"].copy()\n",
    "test_eda = full_fe[full_fe[\"dataset\"] == \"test\"].copy()\n",
    "\n",
    "train_eda[TARGET] = train_eda[TARGET].astype(bool)\n",
    "\n",
    "display(train_eda.head())"
   ]
