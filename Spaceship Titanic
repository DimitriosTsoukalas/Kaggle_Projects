    "def cramers_v(table):\n",
    "    chi2 = chi2_contingency(table)[0]\n",
    "    n = table.sum().sum()\n",
    "    r, k = table.shape\n",
    "\n",
    "    if n == 0 or min(k - 1, r - 1) == 0:\n",
    "        return np.nan\n",
    "\n",
    "    return np.sqrt(chi2 / (n * min(k - 1, r - 1)))\n",
    "\n",
    "\n",
    "def categorical_target_associations(df, categorical_features, target=TARGET):\n",
    "    rows = []\n",
    "\n",
    "    for col in categorical_features:\n",
    "        temp = df[[col, target]].copy()\n",
    "        temp[col] = temp[col].astype(\"object\").fillna(\"Missing\")\n",
    "\n",
    "        table = pd.crosstab(temp[col], temp[target])\n",
    "\n",
    "        chi2, p, dof, expected = chi2_contingency(table)\n",
    "        cv = cramers_v(table)\n",
    "\n",
    "        rates = temp.groupby(col)[target].mean()\n",
    "        rate_spread = rates.max() - rates.min()\n",
    "\n",
    "        rows.append({\n",
    "            \"feature\": col,\n",
    "            \"n_categories\": temp[col].nunique(),\n",
    "            \"chi2_p_value\": p,\n",
    "            \"cramers_v\": cv,\n",
    "            \"target_rate_spread\": rate_spread\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(rows).sort_values(\"cramers_v\", ascending=False)\n",
    "\n",
    "cat_assoc = categorical_target_associations(train, categorical_cols)\n",
    "display(cat_assoc)"
   ]
