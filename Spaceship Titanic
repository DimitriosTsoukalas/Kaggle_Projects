    "def numeric_target_associations(df, numeric_features, target=TARGET):\n",
    "    rows = []\n",
    "\n",
    "    for col in numeric_features:\n",
    "        temp = df[[col, target]].dropna()\n",
    "\n",
    "        if temp.empty or temp[col].nunique() <= 1:\n",
    "            continue\n",
    "\n",
    "        y = temp[target].astype(int)\n",
    "        x = temp[col]\n",
    "\n",
    "        corr, corr_p = pointbiserialr(y, x)\n",
    "\n",
    "        group_false = temp.loc[temp[target] == False, col]\n",
    "        group_true = temp.loc[temp[target] == True, col]\n",
    "\n",
    "        try:\n",
    "            _, mw_p = mannwhitneyu(group_false, group_true, alternative=\"two-sided\")\n",
    "        except ValueError:\n",
    "            mw_p = np.nan\n",
    "\n",
    "        rows.append({\n",
    "            \"feature\": col,\n",
    "            \"point_biserial_corr\": corr,\n",
    "            \"corr_p_value\": corr_p,\n",
    "            \"median_not_transported\": group_false.median(),\n",
    "            \"median_transported\": group_true.median(),\n",
    "            \"mean_not_transported\": group_false.mean(),\n",
    "            \"mean_transported\": group_true.mean(),\n",
    "            \"mannwhitney_p_value\": mw_p\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(rows).sort_values(\n",
    "        \"point_biserial_corr\",\n",
    "        key=lambda s: s.abs(),\n",
    "        ascending=False\n",
    "    )\n",
    "\n",
    "numeric_assoc = numeric_target_associations(train, numeric_cols)\n",
    "display(numeric_assoc)"
   ]
