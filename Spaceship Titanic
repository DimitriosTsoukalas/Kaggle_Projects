    "def target_rate_by_category(df, col, target=TARGET):\n",
    "    summary = (\n",
    "        df.groupby(col, dropna=False)[target]\n",
    "        .agg([\"mean\", \"count\"])\n",
    "        .rename(columns={\"mean\": \"transported_rate\"})\n",
    "        .sort_values(\"transported_rate\", ascending=False)\n",
    "    )\n",
    "    summary[\"transported_rate\"] = summary[\"transported_rate\"] * 100\n",
    "    return summary\n",
    "\n",
    "for col in categorical_cols:\n",
    "    print(f\"\\nTarget rate by {col}\")\n",
    "    display(target_rate_by_category(train, col))\n",
    "\n",
    "    plt.figure(figsize=(8, 4))\n",
    "    sns.barplot(data=train, x=col, y=TARGET)\n",
    "    plt.axhline(train[TARGET].mean(), linestyle=\"--\")\n",
    "    plt.title(f\"Transported Rate by {col}\")\n",
    "    plt.ylabel(\"Transported rate\")\n",
    "    plt.xticks(rotation=30)\n",
    "    plt.show()"
   ]
  },
